<Window x:Class="Agent1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent v1"
        Width="460"
        Height="240"
        MinWidth="420"
        MinHeight="220"
        Topmost="True"
        WindowStyle="None"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        Background="#101418">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Agent v1"
               FontSize="20"
               FontWeight="SemiBold"
               Foreground="#F4F7FA" />

    <Border Grid.Row="1"
            Margin="0,16,0,14"
            Padding="14"
            BorderBrush="#34404B"
            BorderThickness="1"
            CornerRadius="6"
            Background="#182029">
      <TextBlock x:Name="StatusText"
                 TextWrapping="Wrap"
                 FontSize="15"
                 LineHeight="22"
                 Foreground="#E8EEF5" />
    </Border>
  </Grid>
</Window>
