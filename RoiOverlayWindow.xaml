<Window x:Class="Agent1.RoiOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#33000000">
  <Canvas x:Name="RootCanvas" Background="#22000000">
    <Border x:Name="SelectionBorder"
            Visibility="Collapsed"
            BorderThickness="2"
            BorderBrush="#00D1FF"
            Background="#3300D1FF" />
    <Border Canvas.Left="24"
            Canvas.Top="24"
            Padding="12"
            CornerRadius="6"
            Background="#E6101418">
      <TextBlock Text="Выделите ROI прямоугольником мышью"
                 Foreground="#F4F7FA"
                 FontSize="16" />
    </Border>
  </Canvas>
</Window>
